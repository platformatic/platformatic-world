{
  "name": "@platformatic/world",
  "version": "0.6.2",
  "description": "Platformatic World adapter for Vercel Workflow DevKit — drop-in World implementation for self-hosted Kubernetes",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "cbor-x": "1.6.0",
    "undici": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@workflow/world": "4.1.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/platformatic/platformatic-world.git",
    "directory": "packages/world"
  },
  "license": "Apache-2.0"
}
