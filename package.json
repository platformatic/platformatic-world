{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "test": "pnpm --filter '@platformatic/world' --filter '@platformatic/workflow' test",
